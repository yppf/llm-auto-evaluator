      "checks": {
        "must_be_json": true,
        "json_array_length": 5,
        "json_keys_exact": ["name", "input", "k", "expected"],
        "keywords_any": ["k=0", "重复", "负数", "普通"],
        "forbidden_any": ["```", "解释"]
